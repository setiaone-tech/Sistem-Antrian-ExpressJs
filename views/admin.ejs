<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Admin - Antrian Toko</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --primary: #2563eb;
            --success: #16a34a;
            --warning: #ca8a04;
            --danger: #dc2626;
            --dark: #1e293b;
            --bg: #f1f5f9;
        }

        body { font-family: 'Inter', sans-serif; background: var(--bg); margin: 0; padding: 20px; }
        .container { max-width: 1200px; margin: auto; background: white; padding: 25px; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #e2e8f0; padding-bottom: 15px; }
        .search-box { padding: 10px 15px; border: 1px solid #cbd5e1; border-radius: 8px; width: 300px; }

        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; background: var(--dark); color: white; padding: 15px; }
        td { padding: 15px; border-bottom: 1px solid #e2e8f0; }
        tr:hover { background: #f8fafc; }

        .badge { padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .badge-waiting { background: #fef3c7; color: #92400e; }
        .badge-calling { background: #dbeafe; color: #1e40af; animation: pulse 1.5s infinite; }
        .badge-done { background: #dcfce7; color: #166534; }

        .btn { padding: 8px 16px; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; transition: 0.2s; }
        .btn-call { background: var(--primary); color: white; }
        .btn-verify { background: var(--success); color: white; }
        .btn-disabled { background: #cbd5e1; color: #64748b; cursor: not-allowed; }

        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); justify-content: center; align-items: center; z-index: 50; }
        .modal { background: white; padding: 30px; border-radius: 16px; width: 400px; text-align: center; }
        .modal input { width: 100%; padding: 15px; font-size: 24px; text-align: center; border: 2px solid #e2e8f0; border-radius: 12px; margin: 20px 0; text-transform: uppercase; font-weight: bold; letter-spacing: 4px; }

        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>Dashboard Admin</h1>
        <input type="text" id="searchInput" class="search-box" placeholder="Cari Nama atau No. Antri..." onkeyup="filterTable()">
    </div>

    <table id="queueTable">
        <thead>
            <tr>
                <th>No</th>
                <th>Pelanggan</th>
                <th>Kontak</th>
                <th>Timestamp</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody id="queueBody">
            <% list.forEach(item => { %>
                <tr id="row-<%= item._id %>">
                    <td><strong>#<%= item.queue_number %></strong></td>
                    <td><%= item.customer_name %></td>
                    <td><%= item.customer_phone %></td>
                    <td><%= item.createdAt %></td>
                    <td>
                        <span id="badge-<%= item._id %>" class="badge <%= item.status === 'waiting' ? 'badge-waiting' : 'badge-done' %>">
                            <%= item.status %>
                        </span>
                    </td>
                    <td id="action-<%= item._id %>">
                        <% if(item.status === 'waiting') { %>
                            <button id="btn-panggil-<%= item._id %>" class="btn btn-call" onclick="panggilKeLayar('<%= item._id %>')">Panggil</button>
                            <button id="btn-verif-<%= item._id %>" class="btn btn-verify" style="display:none" onclick="openModal('<%= item._id %>', '<%= item.queue_number %>')">Verifikasi Kode</button>
                        <% } else { %>
                            <span style="color: var(--success)">✅ Selesai</span>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="modalOverlay">
    <div class="modal">
        <h3>Verifikasi Antrian #<span id="modalNum"></span></h3>
        <p>Masukkan kode verifikasi dari PDF pelanggan</p>
        <input type="text" id="inputVerifyCode" maxlength="6" placeholder="------">
        <input type="hidden" id="currentQueueId">
        <div style="display: flex; gap: 10px;">
            <button class="btn btn-verify" style="flex: 2; padding: 15px;" onclick="submitVerifikasi()">Konfirmasi</button>
            <button class="btn" style="flex: 1; background: #eee;" onclick="closeModal()">Batal</button>
        </div>
    </div>
</div>

<script>
    const socket = io();

    socket.on('new-queue', (data) => {
        const tbody = document.getElementById('queueBody');
        const row = `
            <tr id="row-${data._id}">
                <td><strong>#${data.queue_number}</strong></td>
                <td>${data.customer_name}</td>
                <td>${data.customer_phone}</td>
                <td>${data.createdAt}</td>
                <td><span id="badge-${data._id}" class="badge badge-waiting">waiting</span></td>
                <td id="action-${data._id}">
                    <button id="btn-panggil-${data._id}" class="btn btn-call" onclick="panggilKeLayar('${data._id}')">Panggil</button>
                    <button id="btn-verif-${data._id}" class="btn btn-verify" style="display:none" onclick="openModal('${data._id}', '${data.queue_number}')">Verifikasi Kode</button>
                </td>
            </tr>`;
        tbody.insertAdjacentHTML('beforeend', row);
    });

    async function panggilKeLayar(id) {
        const res = await fetch(`/admin/panggil/${id}`, { method: 'POST' });
        if(res.ok) {
            document.getElementById(`btn-panggil-${id}`).style.display = 'none';
            document.getElementById(`btn-verif-${id}`).style.display = 'inline-block';
            const badge = document.getElementById(`badge-${id}`);
            badge.innerText = 'Sedang Dipanggil';
            badge.className = 'badge badge-calling';
        }
    }

    function openModal(id, num) {
        document.getElementById('currentQueueId').value = id;
        document.getElementById('modalNum').innerText = num;
        document.getElementById('modalOverlay').style.display = 'flex';
        document.getElementById('inputVerifyCode').focus();
    }

    function closeModal() {
        document.getElementById('modalOverlay').style.display = 'none';
        document.getElementById('inputVerifyCode').value = '';
    }

    async function submitVerifikasi() {
        const id = document.getElementById('currentQueueId').value;
        const code = document.getElementById('inputVerifyCode').value;

        const res = await fetch('/admin/verify-and-process', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, code })
        });

        const result = await res.json();
        if (result.success) {
            closeModal();
        } else {
            alert("Kode Salah! Cek PDF Pelanggan.");
        }
    }

    socket.on('status-finalized', (data) => {
        const badge = document.getElementById(`badge-${data.id}`);
        const action = document.getElementById(`action-${data.id}`);
        if(badge) {
            badge.innerText = 'Telah Diproses';
            badge.className = 'badge badge-done';
        }
        if(action) {
            action.innerHTML = '<span style="color: var(--success)">Selesai</span>';
        }
    });

    function filterTable() {
        const input = document.getElementById("searchInput").value.toUpperCase();
        const rows = document.getElementById("queueBody").getElementsByTagName("tr");
        for (let i = 0; i < rows.length; i++) {
            const txt = rows[i].textContent || rows[i].innerText;
            rows[i].style.display = txt.toUpperCase().indexOf(input) > -1 ? "" : "none";
        }
    }
</script>

</body>
</html>